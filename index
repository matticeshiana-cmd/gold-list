// ── Distill View ──────────────────────────────────────────────────────────────
function DistillView({list,allLists,doDistill,nav}){
  const [knownIds,setKnownIds]=useState(new Set());
  if(!list)return null;
  const toggle=(id)=>setKnownIds(prev=>{const n=new Set(prev);n.has(id)?n.delete(id):n.add(id);return n;});
  const unknownCount=list.entries.length-knownIds.size;
  const allKnown=knownIds.size===list.entries.length;
  return (
    <div className="fade-up">
      <div style={{marginBottom:20}}>
        <div style={{fontSize:11,color:C.muted,textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:4}}>{list.level===0?`Day ${list.dayNumber} Headlist`:`Distillation ${list.level}`}</div>
        <div style={{fontSize:26,fontWeight:700,marginBottom:6}}>{allKnown?"All Known! \uD83C\uDF89":`Carrying forward ${unknownCount}`}</div>
        <div style={{fontSize:14,color:C.muted}}>Tap entries you <strong style={{color:C.green}}>already know</strong>. They won't carry forward.</div>
      </div>
      <div style={{display:"flex",gap:10,marginBottom:20}}>
        <div style={{flex:1,background:C.greenDim,border:`1px solid ${C.green}40`,borderRadius:10,padding:"10px 14px",textAlign:"center"}}><div style={{fontSize:20,fontWeight:700,color:C.green}}>{knownIds.size}</div><div style={{fontSize:11,color:C.muted}}>Known</div></div>
        <div style={{flex:1,background:C.accentDim,border:`1px solid ${C.accent}40`,borderRadius:10,padding:"10px 14px",textAlign:"center"}}><div style={{fontSize:20,fontWeight:700,color:C.accent}}>{unknownCount}</div><div style={{fontSize:11,color:C.muted}}>Carry forward</div></div>
      </div>
      <div style={{display:"flex",flexDirection:"column",gap:6,marginBottom:24}}>
        {list.entries.map(e=>{
          const known=knownIds.has(e.id);
          return <div key={e.id} onClick={()=>toggle(e.id)} style={{background:known?C.greenDim:C.surface,border:`1px solid ${known?C.green+"50":C.border}`,borderRadius:12,padding:"14px 16px",cursor:"pointer",display:"flex",gap:14,alignItems:"flex-start",opacity:known?0.65:1,transition:"all 0.15s"}}>
            <div style={{width:22,height:22,borderRadius:6,flexShrink:0,marginTop:3,border:`2px solid ${known?C.green:C.border}`,background:known?C.green:"transparent",display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:700,color:"#000",transition:"all 0.15s"}}>{known&&"\u2713"}</div>
            <div style={{flex:1}}>
              <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap",marginBottom:4}}>
                <span style={{fontFamily:"Noto Serif KR, serif",fontSize:18,fontWeight:700,textDecoration:known?"line-through":"none",color:known?C.muted:C.text}}>{e.korean}</span>
                <TypePill type={e.type}/>
              </div>
              <div style={{fontSize:14,color:known?C.muted:C.text}}>{e.english}</div>
              {e.note&&<div style={{fontSize:12,color:C.muted,marginTop:4,fontStyle:"italic"}}>{e.note}</div>}
            </div>
          </div>;
        })}
      </div>
      <div style={{display:"flex",gap:10}}>
        <button onClick={()=>nav("dashboard")} style={{flex:1,padding:"14px",border:`1px solid ${C.border}`,borderRadius:12,background:"transparent",cursor:"pointer",fontFamily:"Outfit, sans-serif",fontSize:14,color:C.muted}}>Cancel</button>
        <button onClick={()=>doDistill(list.id,list.entries.map(e=>e.id).filter(id=>!knownIds.has(id)))} style={{flex:2,padding:"14px",border:"none",borderRadius:12,background:allKnown?C.green:C.accent,color:"#000",cursor:"pointer",fontFamily:"Outfit, sans-serif",fontSize:14,fontWeight:700}}>
          {allKnown?"All mastered! Finish \u2713":`Save D${list.level+1} \u2192 ${unknownCount} items`}
        </button>
      </div>
    </div>
  );
}

