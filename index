          <div style={{fontSize:14,color:C.muted}}>{fmtDate(list.createdAt)} \u00B7 {list.entries.length} entries</div>
        </div>
        {s==="ready"&&<button onClick={()=>nav("distillList",list.id)} style={{background:C.green,border:"none",borderRadius:10,padding:"10px 18px",fontFamily:"Outfit, sans-serif",fontSize:13,fontWeight:700,cursor:"pointer",color:"#000"}}>Distill \u2192</button>}
        {s==="waiting"&&<div style={{display:"flex",flexDirection:"column",gap:8,alignItems:"flex-end"}}>
          <div style={{background:C.goldDim,border:`1px solid ${C.gold}40`,borderRadius:10,padding:"10px 16px",fontSize:13,color:C.gold,textAlign:"center"}}><div style={{fontWeight:700}}>{days}d</div><div style={{fontSize:11}}>left</div></div>
          <CalendarButton list={list} compact/>
        </div>}
        {s==="distilled"&&<div style={{fontSize:12,color:C.green,background:C.greenDim,border:`1px solid ${C.green}40`,borderRadius:10,padding:"8px 14px",fontWeight:600}}>\u2713 Distilled</div>}
      </div>
      {[["vocab","\uB2E4\uC5B4"],["grammar","\uBB38\uBC95"],["phrase","\uD45C\uD604"]].map(([key,label])=>{
        const entries=byType[key]; if(!entries.length)return null;
        const tc=TYPE[key];
        return <div key={key} style={{marginBottom:24}}>
          <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10}}>
            <div style={{height:1,flex:1,background:`${tc.color}30`}}/>
            <span style={{fontFamily:"Noto Serif KR, serif",fontSize:12,color:tc.color,fontWeight:700}}>{label}</span>
            <div style={{height:1,flex:1,background:`${tc.color}30`}}/>
          </div>
          <div style={{display:"flex",flexDirection:"column",gap:6}}>{entries.map((e,i)=><EntryRow key={e.id} entry={e} index={i+1}/>)}</div>
        </div>;
      })}
    </div>
  );
}

// ── Calendar Button ───────────────────────────────────────────────────────────
function CalendarButton({list,compact=false}){
  const [clicked,setClicked]=useState(false);
  const handle=()=>{downloadICS(list);setClicked(true);setTimeout(()=>setClicked(false),2500);};
  if(compact)return <button onClick={handle} style={{background:"transparent",border:`1px solid ${C.border}`,borderRadius:8,padding:"5px 10px",cursor:"pointer",fontFamily:"Outfit, sans-serif",fontSize:11,color:clicked?C.green:C.muted,fontWeight:600,display:"flex",alignItems:"center",gap:5,transition:"all 0.2s"}}>{clicked?"\u2713 Downloaded!":"\uD83D\uDCC5 Add to Calendar"}</button>;
  return <button onClick={handle} style={{width:"100%",padding:"11px",border:`1px solid ${clicked?C.green+"60":C.border}`,borderRadius:10,background:clicked?C.greenDim:"transparent",cursor:"pointer",fontFamily:"Outfit, sans-serif",fontSize:14,fontWeight:600,color:clicked?C.green:C.muted,display:"flex",alignItems:"center",justifyContent:"center",gap:8,transition:"all 0.2s"}}>{clicked?"\u2713 Calendar file downloaded!":"\uD83D\uDCC5 Add to Calendar"}</button>;
}

// ── Shared ────────────────────────────────────────────────────────────────────
function EntryRow({entry,index,onDelete}){
  const [hovered,setHovered]=useState(false);
  return <div onMouseEnter={()=>setHovered(true)} onMouseLeave={()=>setHovered(false)}
    style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:12,padding:"13px 16px",display:"flex",gap:12,alignItems:"flex-start"}}>
    <div style={{fontFamily:"DM Mono, monospace",color:C.muted,fontSize:11,paddingTop:4,minWidth:22}}>{String(index).padStart(2,"0")}</div>
    <div style={{flex:1}}>
      <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap",marginBottom:3}}>
        <span style={{fontFamily:"Noto Serif KR, serif",fontSize:18,fontWeight:700}}>{entry.korean}</span>
        <TypePill type={entry.type}/>
      </div>
      <div style={{fontSize:14,color:C.text}}>{entry.english}</div>
      {entry.note&&<div style={{fontSize:12,color:C.muted,marginTop:4,fontStyle:"italic"}}>{entry.note}</div>}
    </div>
    {onDelete&&hovered&&<button onClick={e=>{e.stopPropagation();onDelete();}} style={{background:"transparent",border:"none",color:C.muted,cursor:"pointer",fontSize:18,lineHeight:1,padding:"2px 4px",flexShrink:0}}>\u00D7</button>}
  </div>;
}
function TypePill({type}){
  const t=TYPE[type]||TYPE.vocab;
  return <span style={{background:t.dim,color:t.color,borderRadius:20,padding:"2px 9px",fontSize:11,fontWeight:700}}><span style={{fontFamily:"Noto Serif KR, serif"}}>{t.label}</span></span>;
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
