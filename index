<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Gold List">
  <title>Gold List 금 · Korean</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700&display=swap">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: #0D1117; }
    body { overflow-y: scroll; -webkit-overflow-scrolling: touch; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #30363D; border-radius: 3px; }
    input::placeholder, textarea::placeholder { color: #7D8590; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
    @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }
    .fade-up { animation: fadeUp 0.3s ease forwards; }
    .card-hover { transition: border-color 0.15s, transform 0.15s; }
    .card-hover:hover { border-color: #E8734A !important; transform: translateY(-1px); }
  </style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const { useState, useEffect } = React;

// ── Constants & Helpers ───────────────────────────────────────────────────────
const STORAGE_KEY  = "korean_goldlist_v1";
const API_KEY_KEY  = "goldlist_apikey";
const DISTILL_DAYS = 14;
const MAX_HISTORY  = 15;

const uid        = () => Date.now().toString(36) + Math.random().toString(36).slice(2,7);
const todayStr   = () => new Date().toISOString().slice(0,10);
const addDays    = (d,n) => { const dt=new Date(d); dt.setDate(dt.getDate()+n); return dt.toISOString().slice(0,10); };
const daysUntil  = (d)   => Math.ceil((new Date(d)-new Date(todayStr()))/86400000);
const fmtDate    = (d)   => new Date(d+"T00:00:00").toLocaleDateString("en-US",{month:"short",day:"numeric"});
const fmtDateFull= (d)   => new Date(d+"T00:00:00").toLocaleDateString("en-US",{weekday:"long",month:"long",day:"numeric"});

// ── localStorage helpers ──────────────────────────────────────────────────────
const loadData = () => {
  try { const s=localStorage.getItem(STORAGE_KEY); const d=s?JSON.parse(s):{}; return {lists:[],lookupHistory:[],...d}; }
  catch { return {lists:[],lookupHistory:[]}; }
};
const saveData = (d) => { try { localStorage.setItem(STORAGE_KEY,JSON.stringify(d)); } catch {} };
const getApiKey  = ()  => localStorage.getItem(API_KEY_KEY)||"";
const storeApiKey= (k) => localStorage.setItem(API_KEY_KEY,k);

// ── ICS Helpers ───────────────────────────────────────────────────────────────
function generateICS(label,distillableAt){
  const d=new Date(distillableAt+"T09:00:00"),pad=n=>String(n).padStart(2,"0");
  const fmt=dt=>`${dt.getFullYear()}${pad(dt.getMonth()+1)}${pad(dt.getDate())}T${pad(dt.getHours())}${pad(dt.getMinutes())}00`;
  return ["BEGIN:VCALENDAR","VERSION:2.0","PRODID:-//Korean Gold List//EN","BEGIN:VEVENT",
    `DTSTART:${fmt(d)}`,`DTEND:${fmt(new Date(d.getTime()+3600000))}`,
    `SUMMARY:\uD83C\uDDF0\uD83C\uDDF7 Distill Korean Gold List \u2014 ${label}`,
    `DESCRIPTION:Time to distill ${label}.`,"END:VEVENT","END:VCALENDAR"].join("\r\n");
}
function downloadICS(list){
  const label=list.level===0?`Day ${list.dayNumber} Headlist`:`D${list.level}`;
  const blob=new Blob([generateICS(label,list.distillableAt)],{type:"text/calendar"});
  const url=URL.createObjectURL(blob);
  const a=document.createElement("a");a.href=url;a.download=`goldlist-${label.replace(/\s+/g,"-").toLowerCase()}.ics`;a.click();URL.revokeObjectURL(url);
}

// ── List Helpers ──────────────────────────────────────────────────────────────
const listStatus = (list) => { if(list.distilledTo)return"distilled"; if(daysUntil(list.distillableAt)>0)return"waiting"; return"ready"; };
function getRootDay(list,allLists){ let cur=list; while(cur&&cur.level>0)cur=allLists.find(l=>l.id===cur.parentId); return cur?.dayNumber??"?"; }

// ── Claude API ─────────────────────────────────────────────────────────────────
async function fetchWordBreakdown(word,apiKey){
  const res=await fetch("https://api.anthropic.com/v1/messages",{
    method:"POST",
    headers:{"Content-Type":"application/json","x-api-key":apiKey,
      "anthropic-version":"2023-06-01","anthropic-dangerous-direct-browser-access":"true"},
    body:JSON.stringify({
      model:"claude-sonnet-4-20250514",max_tokens:1000,
      system:`You are a Korean language expert. Analyze the given Korean word. Return ONLY a valid JSON object — no markdown, no backticks, no text outside the JSON.

Schema:
{
  "word":"string","isHomonym":boolean,
  "meanings":[{"hanja":"string or null","label":"short English label","coreMeaning":"2-3 sentence meaning + etymology",
    "exampleSentence":{"korean":"string","english":"string"},
    "contexts":[{"label":"string","icon":"emoji","description":"1-2 sentences","example":{"korean":"string","english":"string"}}],
    "collocations":[{"korean":"string","english":"string"}],
    "comparisons":[{"word":"string","nuance":"string"}],
    "tip":"practical tip"}]
}
4-5 contexts, 5-6 collocations, 3-5 comparisons per meaning.`,
      messages:[{role:"user",content:word}]
    })
  });
  if(!res.ok)throw new Error(res.status);
  const data=await res.json();
  const text=data.content.filter(b=>b.type==="text").map(b=>b.text).join("").replace(/```json|```/g,"").trim();
  return JSON.parse(text);
}

// ── Design Tokens ─────────────────────────────────────────────────────────────
const C={bg:"#0D1117",surface:"#161B22",surface2:"#1C2128",border:"#30363D",text:"#E6EDF3",muted:"#7D8590",
  accent:"#E8734A",accentDim:"#2A1A12",green:"#3FB950",greenDim:"#0F2417",
  gold:"#D4A84B",goldDim:"#1E1A0D",blue:"#58A6FF",blueDim:"#0D1F33",purple:"#A78BFA",purpleDim:"#1A1030"};
const TYPE={
  vocab:  {color:C.blue,  dim:C.blueDim,  label:"\uB2E8\uC5B4",en:"Vocab"},
  grammar:{color:C.purple,dim:C.purpleDim,label:"\uBB38\uBC95",en:"Grammar"},
  phrase: {color:C.gold,  dim:C.goldDim,  label:"\uD45C\uD604",en:"Phrase"},
};
const inputBase={width:"100%",boxSizing:"border-box",padding:"11px 14px",background:C.bg,
  border:`1px solid ${C.border}`,borderRadius:10,color:C.text,fontSize:15,fontFamily:"inherit",outline:"none",transition:"border-color 0.15s"};

// ── App ───────────────────────────────────────────────────────────────────────
function App(){
  const [data,setData]             = useState(loadData);
  const [view,setView]             = useState("dashboard");
  const [selectedId,setSelectedId] = useState(null);
  const [prefill,setPrefill]       = useState(null);
  const [lookupInit,setLookupInit] = useState(null);

  const save = (nd) => { setData(nd); saveData(nd); };

  const todayList  = data.lists.find(l=>l.level===0&&l.createdAt===todayStr())??null;
  const readyLists = data.lists.filter(l=>!l.distilledTo&&listStatus(l)==="ready");

  const createToday = () => {
    const n=data.lists.filter(l=>l.level===0).length, today=todayStr();
    const nl={id:uid(),dayNumber:n+1,level:0,parentId:null,createdAt:today,distillableAt:addDays(today,DISTILL_DAYS),entries:[],distilledTo:null};
    save({...data,lists:[...data.lists,nl]}); setView("today");
  };
  const addEntry = (entry) => {
    if(!todayList||todayList.entries.length>=25)return;
    const updated={...todayList,entries:[...todayList.entries,{id:uid(),...entry}]};
    save({...data,lists:data.lists.map(l=>l.id===todayList.id?updated:l)});
  };
  const removeEntry = (listId,entryId) => {
    save({...data,lists:data.lists.map(l=>l.id===listId?{...l,entries:l.entries.filter(e=>e.id!==entryId)}:l)});
  };
  const doDistill = (sourceId,unknownIds) => {
    const src=data.lists.find(l=>l.id===sourceId); if(!src)return;
    const today=todayStr();
    const newEntries=src.entries.filter(e=>unknownIds.includes(e.id)).map(e=>({...e,id:uid()}));
    const newListId=unknownIds.length>0?uid():"completed";
    const newList=unknownIds.length>0?{id:newListId,dayNumber:null,level:src.level+1,parentId:sourceId,
      createdAt:today,distillableAt:addDays(today,DISTILL_DAYS),entries:newEntries,distilledTo:null}:null;
    save({...data,lists:[...data.lists.map(l=>l.id===sourceId?{...l,distilledTo:newListId}:l),...(newList?[newList]:[])]});
    setView("dashboard");
  };

  const nav            = (v,id=null) => { setView(v); if(id!==null)setSelectedId(id); if(v!=="today")setPrefill(null); if(v!=="lookup")setLookupInit(null); };
  const goLookup       = (word=null) => { setLookupInit(word); setView("lookup"); };
  const goTodayPrefill = (word,ex)   => { setPrefill({korean:word,note:ex}); setView("today"); };

  return (
    <div style={{minHeight:"100vh",background:C.bg,fontFamily:"Outfit, sans-serif",color:C.text}}>
      <Nav view={view} nav={nav} goLookup={goLookup} todayList={todayList} readyCount={readyLists.length}/>
      <div style={{maxWidth:680,margin:"0 auto",padding:"28px 16px 100px"}}>
        {view==="dashboard"   && <Dashboard data={data} todayList={todayList} createToday={createToday} nav={nav}/>}
        {view==="today" && todayList  && <TodayView list={todayList} addEntry={addEntry} removeEntry={removeEntry} prefill={prefill} clearPrefill={()=>setPrefill(null)} goLookup={goLookup}/>}
        {view==="today" && !todayList && <NoTodayList createToday={createToday}/>}
        {view==="lookup"      && <LookupView data={data} save={save} initialWord={lookupInit} todayList={todayList} goTodayPrefill={goTodayPrefill} clearInit={()=>setLookupInit(null)}/>}
        {view==="distill"     && <DistillPicker lists={readyLists} allLists={data.lists} nav={nav}/>}
        {view==="distillList" && selectedId && <DistillView list={data.lists.find(l=>l.id===selectedId)} allLists={data.lists} doDistill={doDistill} nav={nav}/>}
        {view==="viewList"    && selectedId && <ListView list={data.lists.find(l=>l.id===selectedId)} allLists={data.lists} nav={nav}/>}
      </div>
    </div>
  );
}

// ── Nav ───────────────────────────────────────────────────────────────────────
function Nav({view,nav,goLookup,todayList,readyCount}){
  const tabs=[
    {id:"dashboard",icon:"\u25C8",label:"Lists",     action:()=>nav("dashboard")},
    {id:"today",    icon:"\u2746",label:todayList?`Today ${todayList.entries.length}/25`:"Today", action:()=>nav("today")},
    {id:"lookup",   icon:"\u25CE",label:"Look Up",   action:()=>goLookup()},
    ...(readyCount>0?[{id:"distill",icon:"\u25C9",label:`Distill \u00B7 ${readyCount}`,action:()=>nav("distill")}]:[]),
  ];
  const activeTab=view==="distillList"?"distill":view;
  return (
    <nav style={{position:"sticky",top:0,zIndex:20,background:"rgba(13,17,23,0.95)",backdropFilter:"blur(16px)",borderBottom:`1px solid ${C.border}`}}>
      <div style={{maxWidth:680,margin:"0 auto",padding:"0 16px"}}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",height:56}}>
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            <div style={{fontFamily:"Noto Serif KR, serif",fontSize:20,color:C.accent}}>\uAE08</div>
            <div style={{display:"flex",flexDirection:"column"}}>
              <span style={{fontSize:14,fontWeight:600,color:C.text,lineHeight:1.1}}>Gold List</span>
              <span style={{fontSize:10,color:C.muted,letterSpacing:"0.1em",textTransform:"uppercase"}}>\uD55C\uAD6D\uC5B4</span>
            </div>
          </div>
          <div style={{display:"flex",gap:3}}>
            {tabs.map(t=>{
              const active=activeTab===t.id;
              return <button key={t.id} onClick={t.action} style={{padding:"6px 10px",border:active?`1px solid ${C.accent}40`:"1px solid transparent",borderRadius:20,background:active?C.accentDim:"transparent",color:active?C.accent:C.muted,cursor:"pointer",fontSize:12,fontWeight:active?600:400,fontFamily:"Outfit, sans-serif",display:"flex",alignItems:"center",gap:4,transition:"all 0.15s"}}>
                <span style={{fontSize:9}}>{t.icon}</span>{t.label}
              </button>;
            })}
          </div>
        </div>
      </div>
    </nav>
  );
}

// ── Dashboard ─────────────────────────────────────────────────────────────────
function Dashboard({data,todayList,createToday,nav}){
  const headlists=[...data.lists.filter(l=>l.level===0)].sort((a,b)=>b.dayNumber-a.dayNumber);
  const childOf={};
  data.lists.forEach(l=>{if(l.parentId)childOf[l.parentId]=l;});
  const totalEntries=data.lists.reduce((s,l)=>s+(l.level===0?l.entries.length:0),0);
  return (
    <div className="fade-up">
      {!todayList?(
        <button onClick={createToday} style={{width:"100%",padding:"28px",border:`1px dashed ${C.accent}60`,borderRadius:20,background:C.accentDim,cursor:"pointer",textAlign:"left",marginBottom:28,fontFamily:"Outfit, sans-serif",transition:"all 0.2s"}}
          onMouseEnter={e=>{e.currentTarget.style.borderColor=C.accent;e.currentTarget.style.background="#3A1A0E";}}
          onMouseLeave={e=>{e.currentTarget.style.borderColor=`${C.accent}60`;e.currentTarget.style.background=C.accentDim;}}>
          <div style={{fontSize:12,color:`${C.accent}AA`,letterSpacing:"0.1em",textTransform:"uppercase",marginBottom:6}}>{fmtDateFull(todayStr())}</div>
          <div style={{fontSize:22,fontWeight:700,color:C.accent,marginBottom:4}}>Start Today's Headlist \u2192</div>
          <div style={{fontSize:14,color:`${C.accent}80`}}>25 new words \u00B7 Day {data.lists.filter(l=>l.level===0).length+1}</div>
        </button>
      ):(
        <button onClick={()=>nav("today")} style={{width:"100%",padding:"24px 28px",border:`1px solid ${todayList.entries.length>=25?C.green+"60":C.accent+"60"}`,borderRadius:20,background:todayList.entries.length>=25?C.greenDim:C.accentDim,cursor:"pointer",textAlign:"left",marginBottom:28,fontFamily:"Outfit, sans-serif"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <div>
              <div style={{fontSize:12,color:C.muted,letterSpacing:"0.08em",textTransform:"uppercase",marginBottom:6}}>Day {todayList.dayNumber} \u00B7 Today's Headlist</div>
              <div style={{fontSize:20,fontWeight:700,color:todayList.entries.length>=25?C.green:C.accent}}>
                {todayList.entries.length>=25?"Complete! \u2713 Come back in 14 days.":`${todayList.entries.length} / 25 entries added`}
              </div>
            </div>
            <ProgressRing value={todayList.entries.length} max={25} color={todayList.entries.length>=25?C.green:C.accent}/>
          </div>
          {todayList.entries.length<25&&<div style={{marginTop:14,height:4,background:C.border,borderRadius:99,overflow:"hidden"}}><div style={{height:"100%",width:`${(todayList.entries.length/25)*100}%`,background:C.accent,borderRadius:99,transition:"width 0.4s ease"}}/></div>}
        </button>
      )}
      {headlists.length>0&&(
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginBottom:28}}>
          {[{label:"Total Days",value:headlists.length,icon:"\uD83D\uDCC5"},{label:"Total Words",value:totalEntries,icon:"\u270D\uFE0F"},{label:"Ready to Distill",value:data.lists.filter(l=>!l.distilledTo&&listStatus(l)==="ready").length,icon:"\u2728"}].map(s=>(
            <div key={s.label} style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:14,padding:"14px 16px"}}>
              <div style={{fontSize:18,marginBottom:4}}>{s.icon}</div>
              <div style={{fontSize:24,fontWeight:700}}>{s.value}</div>
              <div style={{fontSize:11,color:C.muted,textTransform:"uppercase",letterSpacing:"0.07em"}}>{s.label}</div>
            </div>
          ))}
        </div>
      )}
      {headlists.length===0?(
        <div style={{textAlign:"center",color:C.muted,paddingTop:48}}>
          <div style={{fontFamily:"Noto Serif KR, serif",fontSize:48,marginBottom:16,opacity:0.3}}>\uAE08</div>
          <div style={{fontSize:15}}>No lists yet \u2014 start your first headlist above.</div>
        </div>
      ):(
        <div>
          <div style={{fontSize:11,textTransform:"uppercase",letterSpacing:"0.1em",color:C.muted,marginBottom:14,fontWeight:600}}>Distillation Chains</div>
          {headlists.map(hl=><ListChainRow key={hl.id} headlist={hl} childOf={childOf} nav={nav}/>)}
        </div>
      )}
    </div>
  );
}
function ProgressRing({value,max,color}){
  const r=20,circ=2*Math.PI*r,pct=Math.min(value/max,1);
  return (
    <svg width={52} height={52} viewBox="0 0 52 52">
      <circle cx={26} cy={26} r={r} fill="none" stroke={`${color}20`} strokeWidth={4}/>
      <circle cx={26} cy={26} r={r} fill="none" stroke={color} strokeWidth={4} strokeDasharray={circ} strokeDashoffset={circ*(1-pct)} strokeLinecap="round" transform="rotate(-90 26 26)" style={{transition:"stroke-dashoffset 0.4s ease"}}/>
      <text x={26} y={30} textAnchor="middle" fontSize={11} fontWeight={700} fill={color} fontFamily="Outfit, sans-serif">{value}</text>
    </svg>
  );
}
function ListChainRow({headlist,childOf,nav}){
  const chain=[headlist]; let cur=headlist;
  while(childOf[cur.id]){cur=childOf[cur.id];chain.push(cur);}
  return (
    <div style={{marginBottom:12,display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
      {chain.map((list,i)=>{
        const s=listStatus(list);
        const ss={ready:{border:C.green,bg:C.greenDim,label:"Distill \u2192",lc:C.green},waiting:{border:C.gold,bg:C.goldDim,label:`${daysUntil(list.distillableAt)}d`,lc:C.gold},distilled:{border:C.border,bg:C.surface,label:"\u2713 done",lc:C.muted}}[s];
        return <div key={list.id} style={{display:"flex",alignItems:"center",gap:6}}>
          {i>0&&<div style={{color:C.muted,fontSize:14}}>\u2192</div>}
          <button onClick={()=>s==="ready"?nav("distillList",list.id):nav("viewList",list.id)} className="card-hover"
            style={{background:ss.bg,border:`1px solid ${ss.border}40`,borderRadius:10,padding:"10px 14px",cursor:"pointer",textAlign:"left",fontFamily:"Outfit, sans-serif"}}>
            <div style={{fontSize:12,fontWeight:700,color:C.text,marginBottom:2}}>{list.level===0?`Day ${list.dayNumber}`:`D${list.level}`}</div>
            <div style={{fontSize:11,color:C.muted,marginBottom:6}}>{list.entries.length} entries</div>
            <div style={{fontSize:11,color:ss.lc,fontWeight:600}}>{ss.label}</div>
          </button>
        </div>;
      })}
    </div>
  );
}

// ── Today View ────────────────────────────────────────────────────────────────
function TodayView({list,addEntry,removeEntry,prefill,clearPrefill,goLookup}){
  const [type,setType]   = useState("vocab");
  const [korean,setKorean] = useState("");
  const [english,setEnglish] = useState("");
  const [note,setNote]   = useState("");
  const full = list.entries.length>=25;

  useEffect(()=>{
    if(prefill){ if(prefill.korean)setKorean(prefill.korean); if(prefill.note)setNote(prefill.note); clearPrefill(); setTimeout(()=>document.getElementById("eng-input")?.focus(),100); }
  },[prefill]);

  const handleAdd = () => {
    if(!korean.trim()||!english.trim())return;
    addEntry({type,korean:korean.trim(),english:english.trim(),note:note.trim()});
    setKorean(""); setEnglish(""); setNote("");
    document.getElementById("kor-input")?.focus();
  };
  const handleKey = (e) => { if(e.key==="Enter"&&korean.trim()&&english.trim())handleAdd(); };

  return (
    <div className="fade-up">
      <div style={{marginBottom:24}}>
        <div style={{fontSize:11,color:C.muted,textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:4}}>{fmtDateFull(list.createdAt)}</div>
        <div style={{fontSize:26,fontWeight:700,marginBottom:2}}>Day {list.dayNumber}</div>
        <div style={{color:C.muted,fontSize:14}}>Distillable from <span style={{color:C.text}}>{fmtDateFull(list.distillableAt)}</span></div>
      </div>
      <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:24}}>
        <div style={{flex:1,height:6,background:C.border,borderRadius:99,overflow:"hidden"}}>
          <div style={{height:"100%",width:`${(list.entries.length/25)*100}%`,background:full?C.green:C.accent,borderRadius:99,transition:"width 0.4s ease"}}/>
        </div>
        <span style={{fontSize:13,fontWeight:600,color:full?C.green:C.text,minWidth:48,textAlign:"right"}}>{list.entries.length}/25</span>
      </div>
      {!full&&(
        <div style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:16,padding:20,marginBottom:24}}>
          <div style={{fontSize:12,color:C.muted,textTransform:"uppercase",letterSpacing:"0.08em",marginBottom:14,fontWeight:600}}>Entry #{list.entries.length+1}</div>
          <div style={{display:"flex",gap:8,marginBottom:16}}>
            {Object.entries(TYPE).map(([key,t])=>(
              <button key={key} onClick={()=>setType(key)} style={{padding:"6px 14px",borderRadius:20,border:`1px solid ${type===key?t.color+"80":C.border}`,background:type===key?t.dim:"transparent",color:type===key?t.color:C.muted,cursor:"pointer",fontSize:13,fontWeight:type===key?700:400,fontFamily:"Outfit, sans-serif",transition:"all 0.15s"}}>
                <span style={{fontFamily:"Noto Serif KR, serif",marginRight:4}}>{t.label}</span><span style={{opacity:0.6}}>{t.en}</span>
              </button>
            ))}
          </div>
          <div style={{display:"flex",flexDirection:"column",gap:10}}>
            <div style={{position:"relative"}}>
              <input id="kor-input" value={korean} onChange={e=>setKorean(e.target.value)} onKeyDown={handleKey}
                placeholder={type==="grammar"?"Pattern \u00B7 e.g. ~(\uC73C)\uBA74":"Korean \u00B7 \uD55C\uAD6D\uC5B4"}
                style={{...inputBase,fontFamily:"Noto Serif KR, serif",fontSize:17,paddingRight:korean.trim()?48:14}}
