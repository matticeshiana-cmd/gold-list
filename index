// ── Lookup View ───────────────────────────────────────────────────────────────
function LookupView({data,save,initialWord,todayList,goTodayPrefill,clearInit}){
  const [apiKey,setApiKey]   = useState(getApiKey);
  const [keyInput,setKeyInput] = useState("");
  const [showKey,setShowKey]  = useState(false);
  const [query,setQuery]     = useState(initialWord||"");
  const [result,setResult]   = useState(null);
  const [loading,setLoading] = useState(false);
  const [error,setError]     = useState(null);
  const history = data.lookupHistory||[];

  useEffect(()=>{
    if(initialWord&&apiKey){
      const cached=history.find(h=>h.word===initialWord);
      if(cached){setResult(cached.result);setQuery(initialWord);}
      else doSearch(initialWord);
      clearInit();
    }
  },[]);

  const saveKey = () => {
    if(!keyInput.trim())return;
    storeApiKey(keyInput.trim()); setApiKey(keyInput.trim()); setKeyInput(""); setShowKey(false);
  };

  const doSearch = async (word) => {
    const w=(word||query).trim(); if(!w||!apiKey)return;
    const cached=history.find(h=>h.word===w);
    if(cached){setResult(cached.result);setQuery(w);return;}
    setLoading(true);setError(null);setResult(null);setQuery(w);
    try{
      const r=await fetchWordBreakdown(w,apiKey);
      setResult(r);
      const newHistory=[{word:w,lookedUpAt:todayStr(),result:r},...history.filter(h=>h.word!==w)].slice(0,MAX_HISTORY);
      save({...data,lookupHistory:newHistory});
    }catch(e){
      if(e.message==="401"||e.message==="403")setError("Invalid API key. Please update it below.");
      else setError("Couldn't look up this word. Check spelling and try again.");
    }
    setLoading(false);
  };

  return (
    <div className="fade-up">
      <div style={{marginBottom:20}}>
        <div style={{fontSize:22,fontWeight:700,marginBottom:4}}>Word Lookup</div>
        <div style={{color:C.muted,fontSize:14}}>Full breakdown \u2014 contexts, collocations, comparisons</div>
      </div>

      {/* API key setup — shown when no key or editing */}
      {(!apiKey||showKey)&&(
        <div style={{background:C.surface,border:`1px solid ${C.gold}40`,borderRadius:14,padding:20,marginBottom:20}}>
          <div style={{fontSize:13,fontWeight:600,color:C.gold,marginBottom:6}}>{apiKey?"Update API Key":"Set Up API Key"}</div>
          <div style={{fontSize:13,color:C.muted,marginBottom:14,lineHeight:1.7}}>
            The lookup feature uses Claude AI. Enter your Anthropic API key.<br/>
            Get one free at <a href="https://console.anthropic.com" target="_blank" style={{color:C.blue}}>console.anthropic.com</a>
          </div>
          <div style={{display:"flex",gap:8}}>
            <input type="password" value={keyInput} onChange={e=>setKeyInput(e.target.value)}
              onKeyDown={e=>e.key==="Enter"&&saveKey()}
              placeholder="sk-ant-api03-..."
              style={{...inputBase,flex:1,fontSize:13,fontFamily:"DM Mono, monospace"}}
              onFocus={e=>e.target.style.borderColor=C.gold} onBlur={e=>e.target.style.borderColor=C.border}/>
            <button onClick={saveKey} disabled={!keyInput.trim()} style={{padding:"11px 16px",background:keyInput.trim()?C.gold:C.border,border:"none",borderRadius:10,color:keyInput.trim()?"#000":C.muted,cursor:keyInput.trim()?"pointer":"default",fontFamily:"Outfit, sans-serif",fontSize:13,fontWeight:700,flexShrink:0}}>Save</button>
          </div>
          {apiKey&&<button onClick={()=>setShowKey(false)} style={{marginTop:10,background:"transparent",border:"none",color:C.muted,cursor:"pointer",fontSize:12,fontFamily:"Outfit, sans-serif"}}>Cancel</button>}
          <div style={{marginTop:12,fontSize:11,color:C.muted}}>Your key is stored only on this device and never sent anywhere except Anthropic's servers.</div>
        </div>
      )}

      {/* Search bar */}
      {apiKey&&(
        <>
          <div style={{display:"flex",gap:8,marginBottom:20}}>
            <input value={query} onChange={e=>setQuery(e.target.value)} onKeyDown={e=>e.key==="Enter"&&doSearch()}
              placeholder="\uD55C\uAD6D\uC5B4 \uB2E8\uC5B4 \uC785\uB825..."
              style={{...inputBase,fontFamily:"Noto Serif KR, serif",fontSize:17,flex:1}}
              onFocus={e=>e.target.style.borderColor=C.accent} onBlur={e=>e.target.style.borderColor=C.border}/>
            <button onClick={()=>doSearch()} disabled={!query.trim()||loading} style={{padding:"11px 20px",background:query.trim()&&!loading?C.accent:C.border,border:"none",borderRadius:10,color:query.trim()&&!loading?"#000":C.muted,cursor:query.trim()&&!loading?"pointer":"default",fontFamily:"Outfit, sans-serif",fontSize:14,fontWeight:700,flexShrink:0,transition:"all 0.15s"}}>
              {loading?"...":"Look Up"}
            </button>
          </div>
          {!result&&!loading&&!error&&history.length>0&&(
            <div style={{marginBottom:24}}>
              <div style={{fontSize:11,textTransform:"uppercase",letterSpacing:"0.1em",color:C.muted,marginBottom:10,fontWeight:600}}>Recent</div>
              <div style={{display:"flex",flexWrap:"wrap",gap:8}}>
                {history.map(h=>(
                  <button key={h.word} onClick={()=>{setQuery(h.word);setResult(h.result);}}
                    style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:20,padding:"5px 14px",cursor:"pointer",fontFamily:"Noto Serif KR, serif",fontSize:15,color:C.text,transition:"all 0.15s"}}
                    onMouseEnter={e=>e.currentTarget.style.borderColor=C.accent}
                    onMouseLeave={e=>e.currentTarget.style.borderColor=C.border}>
                    {h.word}
                  </button>
                ))}
              </div>
            </div>
          )}
          {loading&&<LookupLoading word={query}/>}
          {error&&<div style={{background:C.accentDim,border:`1px solid ${C.accent}40`,borderRadius:12,padding:"16px 20px"}}><div style={{fontWeight:600,color:C.accent,marginBottom:4}}>\u26A0\uFE0F Lookup failed</div><div style={{fontSize:13,color:C.muted}}>{error}</div></div>}
          {result&&!loading&&<WordResult result={result} todayList={todayList} goTodayPrefill={goTodayPrefill}/>}
          {/* Change key link at bottom */}
          {!showKey&&<div style={{textAlign:"center",paddingTop:32}}><button onClick={()=>{setShowKey(true);setKeyInput("");}} style={{background:"transparent",border:"none",color:C.muted,cursor:"pointer",fontSize:12,fontFamily:"Outfit, sans-serif"}}>Change API key</button></div>}
        </>
      )}
    </div>
  );
}
